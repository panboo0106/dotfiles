{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(ln:*)"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "alwaysThinkingEnabled": false,
  "hasCompletedOnboarding": true
}
